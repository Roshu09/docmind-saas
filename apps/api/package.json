{
  "name": "@aifi/api",
  "version": "1.0.0",
  "description": "AI File Intelligence - Backend API",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "migrate:up": "node-pg-migrate up --config-file .node-pg-migrate.js --migrations-dir src/db/migrations",
    "migrate:down": "node-pg-migrate down --config-file .node-pg-migrate.js --migrations-dir src/db/migrations",
    "migrate:create": "node-pg-migrate create --config-file .node-pg-migrate.js --migrations-dir src/db/migrations",
    "lint": "eslint src/ --ext .js",
    "test": "jest --coverage"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "bullmq": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.1",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.490.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "express-rate-limit": "^7.1.5",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.6.2",
    "cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "node-pg-migrate": "^6.2.2",
    "eslint": "^8.56.0",
    "jest": "^29.7.0"
  },
  "nodemonConfig": {
    "watch": [
      "src/",
      "server.js"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/",
      "logs/"
    ],
    "delay": 1000
  },
  "type": "module"
}